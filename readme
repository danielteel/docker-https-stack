Make a .env file at top level (same as this readme) with the variables below, customized to your setup

API_VIRTUAL_PATH=/api
API_PORT=3000
DEVICE_PORT=4004

SUPER_PASSWORD=randompasswordhere
SUPER_USERNAME=youremailhere

DESEC_TOKEN=the token you get from DESEC

DOMAIN=your domain (e.g. jeff.dedyn.io)
DESEC_DOMAIN=$DOMAIN
LETSENCRYPT_HOST=$DOMAIN

LETSENCRYPT_EMAIL=your email for lets encrypt purposes

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=databasename
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

EMAIL_HOST=your email host, e.g. smtp.dreamhost.com
EMAIL_USER=your email account, e.g. jeff@verify.jeff.com
EMAIL_PASS=the password to the email account
EMAIL_PORT=465

OMLET_API_KEY=xxxxxxxxxxxxxxxxxxxxxxx

DEVICES=[{"name":"Device1 name","encro_key":"device1 key"},{"name":"Device2 name","encro_key":"device2 key"}]

KASA_PLUGS=[{"id":"lamp","name":"Lamp","ip":"192.168.1.50"}]

PECRON_EMAIL=your pecron account email
PECRON_PASSWORD=your pecron account password
PECRON_REGION=US
PECRON_DEVICE=optional device name, serial, or device key filter
PECRON_WSS_DEVICE_ID=pecron-power-station
PECRON_WSS_POLL_INTERVAL_SECONDS=30

RTSP_DVR_USERNAME=your dvr username
RTSP_DVR_PASSWORD=your dvr password
RTSP_DVR_HOST=ip address of DVR
RTSP_DVR_PORT=554
RTSP_DVR_CHANNELS=1,2,3,4 (add more or take away, this example has 4 cameras)
RTSP_DVR_SUBTYPE=1 (1 is usually lower quality on lorex)
RTSP_CAPTURE_INTERVAL_SECONDS=2
RTSP_STREAM_STALL_SECONDS=15 (restart ffmpeg if no frames arrive for this many seconds; must be at least double RTSP_CAPTURE_INTERVAL_SECONDS)
RTSP_DEVICE_ID_PATTERN=lorex-camera-{channel}
